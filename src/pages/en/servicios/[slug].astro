---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { useTranslations } from '../../../i18n/utils';
import { serviceIcons } from '../../../utils/serviceIcons';

export async function getStaticPaths() {
  const servicios = await getCollection('servicios', s => s.data.lang === 'en');
  return servicios.map(s => ({
    params: { slug: s.slug },
    props:  { servicio: s },
  }));
}

const { servicio } = Astro.props;
const { Content } = await servicio.render();
const { title, summary, icon, photo } = servicio.data;
const t = useTranslations('en');
const svgPath = serviceIcons[icon] ?? serviceIcons['audit'];

const serviciosEs = await getCollection('servicios', s => s.data.lang === 'es');
const equivalenteEs = serviciosEs.find(s => s.data.order === servicio.data.order);
const altLangHrefs = equivalenteEs
  ? { es: `/es/servicios/${equivalenteEs.slug}` }
  : {};
---

<Layout lang="en" title={`${title} — Engineering`}>
  <Navbar lang="en" altLangHrefs={altLangHrefs} />

  <!-- ── Service hero ── -->
  <section class="service-hero relative w-full min-h-[42vh] flex items-end overflow-hidden">

    <!-- Photo or placeholder -->
    {photo ? (
      <img
        src={photo}
        alt={title}
        class="absolute inset-0 w-full h-full object-cover object-center"
      />
    ) : (
      <div class="placeholder-bg absolute inset-0 flex items-center justify-center">
        <svg
          class="placeholder-icon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          set:html={svgPath}
        />
      </div>
    )}

    <!-- Gradient overlay -->
    <div class="hero-overlay absolute inset-0 pointer-events-none" aria-hidden="true"></div>

    <!-- Text over hero -->
    <div class="relative z-10 w-full max-w-300 mx-auto px-6 md:px-16 pb-10 pt-6 flex flex-col gap-4">

      <!-- Back -->
      <a
        href="/en/#servicios"
        class="inline-flex items-center gap-1.5 text-sm text-white/60
               hover:text-white no-underline transition-colors duration-200 w-fit"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
        {t.servicios.volver}
      </a>

      <h1 class="text-[clamp(1.8rem,4vw,3rem)] font-extrabold leading-tight text-white mt-0 mb-0">
        {title}
      </h1>
      <p class="text-[1.05rem] leading-relaxed text-white/70 max-w-2xl mt-0 mb-0">
        {summary}
      </p>

    </div>
  </section>

  <!-- ── Markdown content ── -->
  <section class="content-section w-full px-6 py-14 md:px-16 md:py-20">
    <div class="max-w-3xl mx-auto prose-content">
      <Content />
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="cta-section w-full px-6 py-14 md:px-16">
    <div class="max-w-300 mx-auto cta-card rounded-2xl px-8 py-12 flex flex-col md:flex-row
                items-center justify-between gap-6">
      <div class="flex flex-col gap-2 max-w-xl">
        <h2 class="text-xl font-extrabold text-white mt-0 mb-0">
          {t.servicios.ctaTitulo}
        </h2>
        <p class="text-sm leading-relaxed text-white/65 mt-0 mb-0">
          {t.servicios.ctaDesc}
        </p>
      </div>
      <a
        href="/en/contacto"
        class="shrink-0 bg-white text-(--color-primary) font-semibold text-sm
               px-7 py-3 rounded-lg no-underline transition-all duration-200
               hover:opacity-90 hover:-translate-y-px"
      >
        {t.servicios.ctaBoton}
      </a>
    </div>
  </section>

  <Footer lang="en" />
</Layout>

<style>
  .placeholder-bg {
    background: #080c10;
  }

  .placeholder-icon {
    width: 7rem;
    height: 7rem;
    color: rgba(37, 99, 235, 0.35);
    stroke-width: 1.2;
  }

  .hero-overlay {
    background:
      linear-gradient(to top, rgba(8,12,16,0.92) 0%, rgba(8,12,16,0.4) 50%, rgba(8,12,16,0.25) 100%),
      linear-gradient(to right, rgba(8,12,16,0.5) 0%, transparent 60%);
  }

  .content-section {
    background: var(--color-base);
  }

  .prose-content :global(h2) {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
  }

  .prose-content :global(h3) {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .prose-content :global(p) {
    font-size: 0.95rem;
    line-height: 1.8;
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .prose-content :global(ul),
  .prose-content :global(ol) {
    padding-left: 1.25rem;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .prose-content :global(li) {
    font-size: 0.95rem;
    line-height: 1.7;
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
  }

  .prose-content :global(strong) {
    font-weight: 700;
    color: var(--color-text);
  }

  .prose-content :global(hr) {
    border: none;
    border-top: 1px solid color-mix(in srgb, var(--color-primary) 15%, transparent);
    margin: 2rem 0;
  }

  .cta-section {
    background: color-mix(in srgb, var(--color-primary) 6%, var(--color-base));
  }

  .cta-card {
    background: var(--color-primary);
  }
</style>
