---
import Layout  from '../../layouts/Layout.astro';
import Navbar  from '../../components/Navbar.astro';
import Footer  from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');
const c = t.contacto;
const altLangHrefs = { es: '/es/contacto' };
---

<Layout lang="en" title="Contact — Engineering" description={t.meta.contactDescription}>
  <Navbar slot="navbar" lang="en" altLangHrefs={altLangHrefs} />

  <!-- ── Header ── -->
  <section class="relative overflow-hidden w-full px-6 py-20 md:px-16 md:py-32"
           style="background:#080c10; border-bottom:1px solid var(--color-border);">

    <!-- Background image -->
    <img src="/images/Gemini_Generated_Image_4gw3vv4gw3vv4gw3.webp"
         alt="" aria-hidden="true"
         class="absolute inset-0 w-full h-full object-cover opacity-30"
         loading="eager" />

    <!-- Vignette: top & bottom -->
    <div class="absolute inset-0 pointer-events-none"
         style="background: linear-gradient(to bottom, #080c10 0%, transparent 30%, transparent 70%, #080c10 100%)"></div>
    <!-- Vignette: left & right -->
    <div class="absolute inset-0 pointer-events-none"
         style="background: linear-gradient(to right, #080c10 0%, transparent 45%, #080c10 100%)"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-300 mx-auto">
      <a href="/en/#servicios"
         class="inline-flex items-center gap-1.5 text-sm text-white/50
                hover:text-white no-underline transition-colors duration-200 mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true">
          <path d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
        Back
      </a>

      <span class="inline-flex items-center gap-1.5 mb-5
                   text-[0.72rem] font-bold tracking-[0.12em] uppercase
                   text-(--color-contrast) border border-(--color-contrast)/30
                   px-3.5 py-1.5 rounded-full">
        Contact
      </span>

      <h1 class="text-[clamp(2rem,4.5vw,3.2rem)] font-extrabold leading-tight text-white mt-2 mb-4">
        {c.titulo}
      </h1>
      <p class="text-[1.05rem] leading-relaxed text-white/60 max-w-xl mt-0 mb-0">
        {c.subtitulo}
      </p>
    </div>

  </section>

  <!-- ── Body ── -->
  <section class="w-full bg-(--color-base) px-6 pt-12 pb-20 md:px-16">
    <div class="max-w-300 mx-auto grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16">

      <!-- ── Info ── -->
      <aside class="lg:col-span-2 flex flex-col gap-6">
        <div style="background:#080c10; border:1px solid var(--color-border);"
             class="rounded-2xl p-8 flex flex-col gap-7">

          <h2 class="text-sm font-bold text-white mt-0 mb-0">{c.infoTitulo}</h2>

          <!-- Email -->
          <div class="flex items-start gap-4">
            <div style="background:color-mix(in srgb, var(--color-primary) 12%, transparent); border:1px solid var(--color-border);"
                 class="shrink-0 flex items-center justify-center w-10 h-10 rounded-xl text-(--color-contrast)">
              <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
                   aria-hidden="true">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
            <div class="flex flex-col gap-0.5">
              <span class="text-[0.65rem] font-bold uppercase tracking-widest text-white/35">Email</span>
              <a href="mailto:contacto@ingeniera.com"
                 class="text-sm text-white/65 hover:text-white no-underline transition-colors duration-200">
            proyectos@sigmaprosas.com

              </a>
            </div>
          </div>

          <!-- WhatsApp -->
          <div class="flex items-start gap-4">
            <div style="background:color-mix(in srgb, var(--color-primary) 12%, transparent); border:1px solid var(--color-border);"
                 class="shrink-0 flex items-center justify-center w-10 h-10 rounded-xl text-(--color-contrast)">
              <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
                   aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.08 6.08l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div class="flex flex-col gap-0.5">
              <span class="text-[0.65rem] font-bold uppercase tracking-widest text-white/35">WhatsApp</span>
              <a href="https://wa.me/573000000000" target="_blank" rel="noopener noreferrer"
                 class="text-sm text-white/65 hover:text-white no-underline transition-colors duration-200">
                +57 - 301 812 0983
              </a>
            </div>
          </div>

          <!-- Hours -->
          <div class="flex items-start gap-4">
            <div style="background:color-mix(in srgb, var(--color-primary) 12%, transparent); border:1px solid var(--color-border);"
                 class="shrink-0 flex items-center justify-center w-10 h-10 rounded-xl text-(--color-contrast)">
              <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
                   aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div class="flex flex-col gap-0.5">
              <span class="text-[0.65rem] font-bold uppercase tracking-widest text-white/35">Hours</span>
              <span class="text-sm text-white/65">{c.horario}</span>
            </div>
          </div>

          <!-- Location -->
          <div class="flex items-start gap-4">
            <div style="background:color-mix(in srgb, var(--color-primary) 12%, transparent); border:1px solid var(--color-border);"
                 class="shrink-0 flex items-center justify-center w-10 h-10 rounded-xl text-(--color-contrast)">
              <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
                   aria-hidden="true">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div class="flex flex-col gap-0.5">
              <span class="text-[0.65rem] font-bold uppercase tracking-widest text-white/35">Location</span>
              <span class="text-sm text-white/65">{c.ubicacion}</span>
            </div>
          </div>

          <!-- Divider -->
          <div style="background:var(--color-border);" class="h-px w-full"></div>

          <!-- Social -->
          <!-- <div class="flex items-center gap-3">
            {[
              { href: 'https://wa.me/573000000000', label: 'WhatsApp', svg: `<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>`, fill: true },
              { href: 'https://instagram.com/ingeniera', label: 'Instagram', svg: `<rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>`, fill: false },
              { href: 'https://facebook.com/ingeniera', label: 'Facebook', svg: `<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>`, fill: false },
            ].map(({ href, label, svg, fill }) => (
              <a href={href} target="_blank" rel="noopener noreferrer" aria-label={label}
                 style="background:color-mix(in srgb, var(--color-primary) 10%, transparent); border:1px solid var(--color-border);"
                 class="flex items-center justify-center w-11 h-11 rounded-lg no-underline
                        text-white/50 hover:text-(--color-contrast) transition-colors duration-200">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24"
                     fill={fill ? 'currentColor' : 'none'}
                     stroke={fill ? 'none' : 'currentColor'}
                     stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true"
                     set:html={svg} />
              </a>
            ))}
          </div> -->

        </div>
      </aside>

      <!-- ── Form ── -->
      <div class="lg:col-span-3">
        <div style="background:var(--color-surface); border:1px solid var(--color-border);"
             class="rounded-2xl p-8 md:p-10">

          <h2 class="text-sm font-bold text-(--color-text) mt-0 mb-8">{c.formTitulo}</h2>

          <form id="contact-form" method="post" class="flex flex-col gap-6" novalidate>

            <!-- Name + Email -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div class="flex flex-col gap-1.5">
                <label for="nombre" class="text-[0.78rem] font-semibold text-(--color-text)/70 flex items-center gap-1.5">
                  {c.nombre} <span class="text-(--color-primary)">*</span>
                </label>
                <input id="nombre" name="nombre" type="text" placeholder={c.nombrePH} required autocomplete="name"
                       class="w-full px-3.5 py-2.5 text-sm text-(--color-text) bg-(--color-base)
                              border border-(--color-border) rounded-lg outline-none
                              placeholder:text-(--color-text)/40
                              focus:border-(--color-primary) focus:ring-3 focus:ring-(--color-primary)/10
                              transition-colors duration-150" />
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="email" class="text-[0.78rem] font-semibold text-(--color-text)/70 flex items-center gap-1.5">
                  {c.email} <span class="text-(--color-primary)">*</span>
                </label>
                <input id="email" name="email" type="email" placeholder={c.emailPH} required autocomplete="email"
                       class="w-full px-3.5 py-2.5 text-sm text-(--color-text) bg-(--color-base)
                              border border-(--color-border) rounded-lg outline-none
                              placeholder:text-(--color-text)/40
                              focus:border-(--color-primary) focus:ring-3 focus:ring-(--color-primary)/10
                              transition-colors duration-150" />
              </div>
            </div>

            <!-- Phone + Company -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div class="flex flex-col gap-1.5">
                <label for="telefono" class="text-[0.78rem] font-semibold text-(--color-text)/70 flex items-center gap-2">
                  {c.telefono}
                  <span class="text-[0.65rem] font-normal text-(--color-text)/50 bg-(--color-surface-2) px-2 py-0.5 rounded-full">
                    {c.opcional}
                  </span>
                </label>
                <input id="telefono" name="telefono" type="tel" placeholder={c.telefonoPH} autocomplete="tel"
                       class="w-full px-3.5 py-2.5 text-sm text-(--color-text) bg-(--color-base)
                              border border-(--color-border) rounded-lg outline-none
                              placeholder:text-(--color-text)/40
                              focus:border-(--color-primary) focus:ring-3 focus:ring-(--color-primary)/10
                              transition-colors duration-150" />
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="empresa" class="text-[0.78rem] font-semibold text-(--color-text)/70 flex items-center gap-2">
                  {c.empresa}
                  <span class="text-[0.65rem] font-normal text-(--color-text)/50 bg-(--color-surface-2) px-2 py-0.5 rounded-full">
                    {c.opcional}
                  </span>
                </label>
                <input id="empresa" name="empresa" type="text" placeholder={c.empresaPH} autocomplete="organization"
                       class="w-full px-3.5 py-2.5 text-sm text-(--color-text) bg-(--color-base)
                              border border-(--color-border) rounded-lg outline-none
                              placeholder:text-(--color-text)/40
                              focus:border-(--color-primary) focus:ring-3 focus:ring-(--color-primary)/10
                              transition-colors duration-150" />
              </div>
            </div>

            <!-- Service -->
            <div class="flex flex-col gap-1.5">
              <label for="servicio" class="text-[0.78rem] font-semibold text-(--color-text)/70">
                {c.servicio}
              </label>
              <div class="relative">
                <select id="servicio" name="servicio"
                        class="w-full appearance-none px-3.5 py-2.5 pr-10 text-sm text-(--color-text) bg-(--color-base)
                               border border-(--color-border) rounded-lg outline-none cursor-pointer
                               focus:border-(--color-primary) focus:ring-3 focus:ring-(--color-primary)/10
                               transition-colors duration-150">
                  <option value="" disabled selected>{c.servicioDefault}</option>
                  {c.servicios.map((s: string) => (
                    <option value={s}>{s}</option>
                  ))}
                </select>
                <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-(--color-text)/40"
                     xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </div>
            </div>

            <!-- Message -->
            <div class="flex flex-col gap-1.5">
              <label for="mensaje" class="text-[0.78rem] font-semibold text-(--color-text)/70 flex items-center gap-1.5">
                {c.mensaje} <span class="text-(--color-primary)">*</span>
              </label>
              <textarea id="mensaje" name="mensaje" placeholder={c.mensajePH} required rows="5"
                        class="w-full px-3.5 py-2.5 text-sm text-(--color-text) bg-(--color-base)
                               border border-(--color-border) rounded-lg outline-none resize-y
                               placeholder:text-(--color-text)/40
                               focus:border-(--color-primary) focus:ring-3 focus:ring-(--color-primary)/10
                               transition-colors duration-150 font-[inherit]">
              </textarea>
            </div>

            <!-- Footer -->
            <div class="flex items-center justify-between gap-4 flex-wrap pt-1">
              <p class="text-xs text-(--color-text)/40 m-0">* {c.nombre} and {c.mensaje} are required</p>
              <button type="submit"
                      class="inline-flex items-center gap-2 bg-(--color-green) text-white
                             text-sm font-semibold px-6 py-2.5 rounded-lg border-none cursor-pointer
                             hover:bg-(--color-green-soft) hover:-translate-y-px transition-all duration-200">
                {c.enviar}
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </button>
            </div>

          </form>

          <!-- Result -->
          <div id="form-result" class="hidden mt-4 px-4 py-3 rounded-lg text-sm font-medium"></div>

        </div>
      </div>

    </div>
  </section>

  <Footer slot="footer" lang="en" />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const result = document.getElementById('form-result');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !result) return;

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const original = btn.innerHTML;
    btn.disabled = true;
    btn.textContent = 'Sending…';

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json() as { ok?: boolean; error?: string };

      result.classList.remove('hidden');

      if (json.ok) {
        result.style.cssText = 'background:#f0fdf4;color:#166534;border:1px solid #bbf7d0';
        result.textContent = 'Message sent! We will get back to you shortly.';
        form.reset();
      } else {
        result.style.cssText = 'background:#fef2f2;color:#991b1b;border:1px solid #fecaca';
        result.textContent = json.error ?? 'Something went wrong. Please try again.';
      }
    } catch {
      result.classList.remove('hidden');
      result.style.cssText = 'background:#fef2f2;color:#991b1b;border:1px solid #fecaca';
      result.textContent = 'Connection error. Please try again.';
    } finally {
      btn.disabled = false;
      btn.innerHTML = original;
    }
  });
</script>
