---
// prettier-ignore
import Layout        from "../../layouts/Layout.astro";
// prettier-ignore
import Navbar        from "../../components/Navbar.astro";
// prettier-ignore
import Hero          from "../../components/Hero.astro";
// prettier-ignore
import ComoTrabajamos from "../../components/ComoTrabajamos.astro";
// prettier-ignore
import Servicios     from "../../components/Servicios.astro";
// prettier-ignore
import Equipo        from "../../components/Equipo.astro";
// prettier-ignore
import Nosotros      from "../../components/Nosotros.astro";
// prettier-ignore
import Footer        from "../../components/Footer.astro";
import { useTranslations } from "../../i18n/utils";
const t = useTranslations("en");
---

<Layout lang="en" title="Engineering" description={t.meta.homeDescription}>
  <Navbar slot="navbar" lang="en" />
  <Hero lang="en" />
  <Nosotros lang="en" />
  <!-- <ComoTrabajamos lang="en" /> -->
  <Servicios lang="en" />
  <Equipo lang="en" />
  <Footer slot="footer" lang="en" />
</Layout>
