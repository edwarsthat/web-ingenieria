---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const navLinks = [
  { href: `/${lang}/#inicio`,    label: t.nav.inicio    },
  { href: `/${lang}/#servicios`, label: t.nav.servicios },
  { href: `/${lang}/#nosotros`,  label: t.nav.nosotros  },
  { href: `/${lang}/#contacto`,  label: t.nav.contacto  },
];

const year = new Date().getFullYear();
---

<footer class="footer-section w-full px-6 pt-14 pb-6 md:px-16">
  <div class="max-w-300 mx-auto flex flex-col gap-12">

    <!-- ── Fila principal ── -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Col 1: Marca + descripción -->
      <div class="flex flex-col gap-4">
        <a href={`/${lang}/`} class="text-xl font-bold tracking-wide no-underline text-white">
          <span class="text-(--color-contrast)">ING</span>ENIERA
        </a>
        <p class="text-sm leading-relaxed text-white/45 mt-0 mb-0 max-w-xs">
          {t.footer.desc}
        </p>
      </div>

      <!-- Col 2: Navegación -->
      <div class="flex flex-col gap-4">
        <h3 class="text-xs font-bold uppercase tracking-[0.1em] text-white/35 mt-0 mb-0">
          {t.footer.navTitle}
        </h3>
        <ul class="flex flex-col gap-2.5 list-none m-0 p-0">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm text-white/55 hover:text-white no-underline transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Contacto + redes -->
      <div class="flex flex-col gap-4">
        <h3 class="text-xs font-bold uppercase tracking-[0.1em] text-white/35 mt-0 mb-0">
          {t.footer.contactTitle}
        </h3>

        <div class="flex flex-col gap-3">

          <!-- Email -->
          <a
            href="mailto:contacto@ingeniera.com"
            class="flex items-center gap-2.5 text-sm text-white/55 hover:text-white no-underline transition-colors duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-(--color-contrast)">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            contacto@ingeniera.com
          </a>

          <!-- Teléfono / WhatsApp -->
          <a
            href="https://wa.me/573000000000"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2.5 text-sm text-white/55 hover:text-white no-underline transition-colors duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-(--color-contrast)">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.08 6.08l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            +57 300 000 0000
          </a>

        </div>

        <!-- Redes sociales -->
        <div class="flex items-center gap-3 mt-1">

          <!-- Instagram -->
          <a
            href="https://instagram.com/ingeniera"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="social-icon"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
            </svg>
          </a>

          <!-- Facebook -->
          <a
            href="https://facebook.com/ingeniera"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="social-icon"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>

          <!-- WhatsApp -->
          <a
            href="https://wa.me/573000000000"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp"
            class="social-icon"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
            </svg>
          </a>

        </div>
      </div>

    </div>

    <!-- ── Línea divisora ── -->
    <div class="divider-line h-px w-full"></div>

    <!-- ── Copyright ── -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-2 pb-2">
      <p class="text-xs text-white/30 m-0">
        © {year} Ingeniera. {t.footer.rights}
      </p>
      <p class="text-xs text-white/20 m-0">
        {t.footer.location}
      </p>
    </div>

  </div>
</footer>

<style>
  .footer-section {
    background: #080c10;
    border-top: 1px solid rgba(37, 99, 235, 0.2);
  }

  .divider-line {
    background: rgba(37, 99, 235, 0.15);
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    color: rgba(255, 255, 255, 0.5);
    background: rgba(37, 99, 235, 0.1);
    border: 1px solid rgba(37, 99, 235, 0.2);
    transition: all 0.2s;
    text-decoration: none;
  }

  .social-icon:hover {
    color: #38BDF8;
    background: rgba(37, 99, 235, 0.2);
    border-color: rgba(37, 99, 235, 0.45);
  }
</style>
