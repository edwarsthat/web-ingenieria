---
import { getCollection } from 'astro:content';
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import EquipoCard from './equipo/EquipoCard.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const miembros = (await getCollection('equipo'))
  .filter(m => m.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);
---

<section
  id="equipo"
  class="equipo-section w-full px-6 pt-10 pb-18 md:px-16 md:pt-14 md:pb-28"
>
  <div class="max-w-300 mx-auto flex flex-col gap-14">

    <!-- ── Intro ── -->
    <div class="flex flex-col items-center text-center gap-4 max-w-2xl mx-auto">

      <p class="text-[0.72rem] font-bold tracking-[0.14em] uppercase text-(--color-primary)/55 mt-0 mb-0">
        {t.equipo.badge}
      </p>

      <h2 class="text-[clamp(1.8rem,3.5vw,2.8rem)] font-extrabold leading-[1.15]
                 mt-0 mb-0 text-(--color-text)">
        {t.equipo.titulo}
      </h2>

      <p class="text-[1.05rem] leading-[1.75] text-(--color-text)/60 mt-0 mb-0">
        {t.equipo.desc}
      </p>

    </div>

    <!-- ── Cards ── -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
      {miembros.map(m => (
        <EquipoCard
          name={m.data.name}
          role={m.data.role}
          bio={m.data.bio}
          initials={m.data.initials}
          specialty={m.data.specialty}
          photo={m.data.photo}
        />
      ))}
    </div>

  </div>
</section>

<style>
  .equipo-section {
    background: color-mix(in srgb, var(--color-primary) 4%, var(--color-base));
  }
</style>
