---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const sectores = [
  {
    label: t.sectoresValor.s1,
    svg: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M3 6l3 1m0 0l-3 9a5 5 0 0 0 6.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5 5 0 0 0 6.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/>`,
  },
  {
    label: t.sectoresValor.s2,
    svg: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M3.055 11H5a2 2 0 0 1 2 2v1a2 2 0 0 0 2 2 2 2 0 0 1 2 2v2.945"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M8 3.935V5.5A2.5 2.5 0 0 0 10.5 8h.5a2 2 0 0 1 2 2 2 2 0 0 0 4 0 2 2 0 0 1 2-2h1.064"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>`,
  },
  {
    label: t.sectoresValor.s3,
    svg: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M19.428 15.428a2 2 0 0 0-1.022-.547l-2.387-.477a6 6 0 0 0-3.86.517l-.318.158a6 6 0 0 1-3.86.517L6.05 15.21a2 2 0 0 0-1.806.547M8 4h8l-1 1v5.172a2 2 0 0 0 .586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 0 0 9 10.172V5L8 4z"/>`,
  },
  {
    label: t.sectoresValor.s4,
    svg: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M19 11H5m14 0a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-6a2 2 0 0 1 2-2m14 0V9a2 2 0 0 0-2-2M5 11V9a2 2 0 0 1 2-2m0 0V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2M7 7h10"/>`,
  },
  {
    label: t.sectoresValor.s5,
    svg: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  },
  {
    label: t.sectoresValor.s6,
    svg: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 0 0 1 1h3m10-11l2 2m-2-2v10a1 1 0 0 1-1 1h-3m-6 0a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1m-6 0h6"/>`,
  },
  {
    label: t.sectoresValor.s7,
    svg: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M4 4v5h.582m15.356 2A8.001 8.001 0 0 0 4.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 0 1-15.357-2m15.357 2H15"/>`,
  },
];
---

<section id="sectores-valor" class="sectores-section w-full px-6 pt-16 pb-20 md:px-16 md:pt-20 md:pb-28">
  <div class="max-w-300 mx-auto flex flex-col gap-12">

    <!-- Intro -->
    <div class="flex flex-col items-center text-center gap-4 max-w-2xl mx-auto">

      <p class="text-[0.72rem] font-bold tracking-[0.14em] uppercase text-(--color-primary)/55">
        {t.sectoresValor.badge}
      </p>

      <h2 class="text-[clamp(1.8rem,3.5vw,2.8rem)] font-extrabold leading-[1.15] text-(--color-text) mt-0 mb-0">
        {t.sectoresValor.titulo}
      </h2>

      <p class="text-[1.05rem] leading-[1.75] text-(--color-text)/60 mt-0 mb-0">
        {t.sectoresValor.desc}
      </p>

    </div>

    <!-- Grid de sectores -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {sectores.map((s, i) => (
        <div
          class="sector-card flex items-center gap-4 px-5 py-4 rounded-xl"
          data-reveal
          data-delay={String(i % 4)}
        >
          <div class="sector-icon shrink-0 w-10 h-10 rounded-lg flex items-center justify-center">
            <svg
              class="w-5 h-5 text-(--color-primary)"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              set:html={s.svg}
            />
          </div>
          <span class="text-[0.9375rem] font-semibold text-(--color-text) leading-snug">
            {s.label}
          </span>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .sectores-section {
    background: color-mix(in srgb, var(--color-primary) 4%, var(--color-base));
  }

  .sector-card {
    background: var(--color-base);
    border: 1px solid color-mix(in srgb, var(--color-primary) 12%, transparent);
    transition: border-color 240ms cubic-bezier(0.25, 1, 0.5, 1),
                transform     240ms cubic-bezier(0.25, 1, 0.5, 1),
                box-shadow    240ms cubic-bezier(0.25, 1, 0.5, 1);
  }
  .sector-card:hover {
    border-color: color-mix(in srgb, var(--color-primary) 32%, transparent);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--color-primary) 8%, transparent);
  }

  .sector-icon {
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    transition: background 240ms;
  }
  .sector-card:hover .sector-icon {
    background: color-mix(in srgb, var(--color-primary) 16%, transparent);
  }
</style>
