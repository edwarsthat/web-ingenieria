---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const principios = [
  {
    title: t.nuestroEnfoque.p1Titulo,
    desc:  t.nuestroEnfoque.p1Desc,
    svg: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066
               c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 0 0 1.065 2.572
               c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 0 0-1.066 2.573
               c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 0 0-2.572 1.065
               c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 0 0-2.573-1.066
               c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 0 0-1.065-2.572
               c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 0 0 1.066-2.573
               c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
          <circle cx="12" cy="12" r="3" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"/>`,
  },
  {
    title: t.nuestroEnfoque.p2Titulo,
    desc:  t.nuestroEnfoque.p2Desc,
    svg: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M3 3v18h18"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M7 16l4-5 4 3 4-6"/>`,
  },
  {
    title: t.nuestroEnfoque.p3Titulo,
    desc:  t.nuestroEnfoque.p3Desc,
    svg: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>`,
  },
  {
    title: t.nuestroEnfoque.p4Titulo,
    desc:  t.nuestroEnfoque.p4Desc,
    svg: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M9 12l2 2 4-4"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>`,
  },
];
---

<section id="nuestro-enfoque" class="enfoque-section w-full px-6 pt-16 pb-20 md:px-16 md:pt-20 md:pb-28">
  <div class="max-w-300 mx-auto flex flex-col gap-14">

    <!-- Intro -->
    <div class="flex flex-col items-center text-center gap-4 max-w-2xl mx-auto">

      <p class="text-[0.72rem] font-bold tracking-[0.14em] uppercase text-(--color-primary)/55">
        {t.nuestroEnfoque.badge}
      </p>

      <h2 class="text-[clamp(1.8rem,3.5vw,2.8rem)] font-extrabold leading-[1.15] text-(--color-text) mt-0 mb-0">
        {t.nuestroEnfoque.titulo}
      </h2>

      <p class="text-[1.05rem] leading-[1.75] text-(--color-text)/60 mt-0 mb-0">
        {t.nuestroEnfoque.desc}
      </p>

    </div>

    <!-- Tarjetas de principios -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {principios.map((p, i) => (
        <div class="principio-card flex flex-col gap-5 p-6 rounded-2xl" data-reveal data-delay={String(i)}>

          <!-- Ícono -->
          <div class="principio-icon w-11 h-11 rounded-xl flex items-center justify-center shrink-0">
            <svg
              class="w-5 h-5 text-(--color-primary)"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              set:html={p.svg}
            />
          </div>

          <!-- Texto -->
          <div class="flex flex-col gap-2">
            <h3 class="text-[0.9375rem] font-bold text-(--color-text) mt-0 mb-0 leading-snug">
              {p.title}
            </h3>
            <p class="text-sm leading-relaxed text-(--color-text)/60 mt-0 mb-0">
              {p.desc}
            </p>
          </div>

          <!-- Acento inferior -->
          <div class="principio-accent mt-auto h-0.5 w-8 rounded-full"></div>

        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .enfoque-section {
    background: var(--color-base);
  }

  .principio-card {
    background: color-mix(in srgb, var(--color-primary) 4%, var(--color-base));
    border: 1px solid color-mix(in srgb, var(--color-primary) 12%, transparent);
    transition: border-color 240ms cubic-bezier(0.25, 1, 0.5, 1),
                transform     240ms cubic-bezier(0.25, 1, 0.5, 1),
                box-shadow    240ms cubic-bezier(0.25, 1, 0.5, 1);
  }
  .principio-card:hover {
    border-color: color-mix(in srgb, var(--color-primary) 32%, transparent);
    transform: translateY(-3px);
    box-shadow: 0 6px 24px color-mix(in srgb, var(--color-primary) 8%, transparent);
  }

  .principio-icon {
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
  }

  .principio-accent {
    background: var(--color-primary);
    opacity: 0.35;
    transition: width 240ms cubic-bezier(0.25, 1, 0.5, 1), opacity 240ms;
  }
  .principio-card:hover .principio-accent {
    width: 2.5rem;
    opacity: 0.7;
  }
</style>
