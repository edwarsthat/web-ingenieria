---
import { serviceIcons } from '../../utils/serviceIcons';

interface Props {
  titulo: string;
  desc:   string;
  icono:  string;
  color:  string;
  href:   string;
  label:  string;
  slug:   string;
}

const { titulo, desc, icono, color, href, label, slug } = Astro.props;
const svgPath = serviceIcons[icono] ?? serviceIcons['audit'];
---

<div
  class="servicio-card group flex flex-col gap-5 p-8 rounded-2xl min-h-72
         transition-all duration-200 hover:-translate-y-1 hover:shadow-2xl"
  style={`--card-color: ${color};`}
>

  <div transition:name={`icon-${slug}`} class="card-icon w-12 h-12 rounded-xl flex items-center justify-center shrink-0">
    <svg
      class="w-6 h-6 text-white"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      set:html={svgPath}
    />
  </div>

  <div class="flex flex-col flex-1 gap-3">
    <h3 class="text-base font-bold text-white mt-0 mb-0">
      {titulo}
    </h3>
    <p class="text-sm leading-relaxed text-white/70 mt-0 mb-0">
      {desc}
    </p>
  </div>

  <div class="flex items-center justify-between mt-auto">
    <div class="h-0.5 w-10 rounded-full bg-white/30"></div>
    <a
      href={href}
      class="flex items-center gap-1.5 text-xs font-semibold text-white/70
             hover:text-white no-underline transition-colors duration-200"
    >
      {label}
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>

</div>

<style>
  .servicio-card {
    background-color: var(--card-color);
  }
  .servicio-card:hover {
    background-color: color-mix(in srgb, var(--card-color) 85%, white);
  }
  .card-icon {
    background-color: rgba(255, 255, 255, 0.15);
  }
</style>
