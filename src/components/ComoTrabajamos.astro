---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const steps = [
  {
    num:   '01',
    title: t.comoTrabajamos.step1Title,
    desc:  t.comoTrabajamos.step1Desc,
    svg: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M21 21l-4.35-4.35"/>
          <circle cx="11" cy="11" r="8" stroke-width="1.8"/>`,
  },
  {
    num:   '02',
    title: t.comoTrabajamos.step2Title,
    desc:  t.comoTrabajamos.step2Desc,
    svg: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2 2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M12 12h4M12 16h4M8 12h.01M8 16h.01"/>`,
  },
  {
    num:   '03',
    title: t.comoTrabajamos.step3Title,
    desc:  t.comoTrabajamos.step3Desc,
    svg: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>`,
  },
  {
    num:   '04',
    title: t.comoTrabajamos.step4Title,
    desc:  t.comoTrabajamos.step4Desc,
    svg: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" points="14 2 14 8 20 8"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M16 13H8M16 17H8M10 9H8"/>`,
  },
];
---

<section
  id="como-trabajamos"
  class="como-section w-full px-6 pt-10 pb-18 md:px-16 md:pt-14 md:pb-28"
>
  <div class="max-w-300 mx-auto flex flex-col gap-14">

    <!-- ── Intro ── -->
    <div class="flex flex-col items-center text-center gap-4 max-w-2xl mx-auto">

      <span class="inline-flex items-center gap-1.5
                   text-[0.72rem] font-bold tracking-[0.12em] uppercase
                   text-(--color-contrast) border border-(--color-contrast)/30
                   px-3.5 py-1.5 rounded-full">
        {t.comoTrabajamos.badge}
      </span>

      <h2 class="text-[clamp(1.8rem,3.5vw,2.8rem)] font-extrabold leading-[1.15]
                 mt-0 mb-0 text-(--color-text)">
        {t.comoTrabajamos.titulo}
      </h2>

      <p class="text-[1.05rem] leading-[1.75] text-(--color-text)/60 mt-0 mb-0">
        {t.comoTrabajamos.desc}
      </p>

    </div>

    <!-- ── Pasos ── -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      {steps.map((step, i) => (
        <div class="relative flex flex-col">

          <!-- Línea conectora horizontal (solo desktop, no en el último) -->
          {i < steps.length - 1 && (
            <div
              class="connector-line hidden md:block absolute top-[1.35rem] left-[calc(50%+1.6rem)] w-[calc(100%-3.2rem)] h-px"
              aria-hidden="true"
            />
          )}

          <!-- Tarjeta -->
          <div class="step-card flex flex-col gap-5 p-6 rounded-2xl">

            <!-- Número y ícono -->
            <div class="flex items-center gap-3">
              <div class="step-num shrink-0 w-11 h-11 rounded-full flex items-center justify-center
                          text-sm font-extrabold tracking-wide text-white">
                {step.num}
              </div>
              <div class="step-icon w-9 h-9 rounded-xl flex items-center justify-center shrink-0">
                <svg
                  class="w-5 h-5 text-(--color-primary)"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  set:html={step.svg}
                />
              </div>
            </div>

            <!-- Texto -->
            <div class="flex flex-col gap-2">
              <h3 class="text-base font-bold text-(--color-text) mt-0 mb-0">
                {step.title}
              </h3>
              <p class="text-sm leading-relaxed text-(--color-text)/60 mt-0 mb-0">
                {step.desc}
              </p>
            </div>

          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .como-section {
    background: color-mix(in srgb, var(--color-primary) 4%, var(--color-base));
  }

  .step-card {
    background: var(--color-base);
    border: 1px solid color-mix(in srgb, var(--color-primary) 12%, transparent);
    transition: border-color 0.2s, transform 0.2s;
  }
  .step-card:hover {
    border-color: color-mix(in srgb, var(--color-primary) 35%, transparent);
    transform: translateY(-2px);
  }

  .step-num {
    background: var(--color-primary);
  }

  .step-icon {
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
  }

  .connector-line {
    background: color-mix(in srgb, var(--color-primary) 25%, transparent);
  }
</style>
