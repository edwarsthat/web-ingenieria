---
interface Props {
  class?: string;
  size?: number;
  variant?: "light" | "dark";
}

const { class: className = "", size = 40, variant = "light" } = Astro.props;
---

<img
  src="/logo.svg"
  width={size}
  height={size}
  alt="Ingeniera"
  class:list={[className, { "logo-dark": variant === "dark" }]}
  loading="eager"
/>

<style>
  .logo-dark {
    filter: brightness(0) invert(1);
  }
</style>
